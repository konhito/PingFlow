# Custom JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_min_32_characters_long
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# GitHub OAuth
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/pingflow"

# Kafka (for microservices architecture)
KAFKA_BROKERS="localhost:29092"

# Discord Integration
DISCORD_BOT_TOKEN="your_discord_bot_token"

# Stripe Payment Integration
STRIPE_SECRET_KEY="sk_test_your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="whsec_your_stripe_webhook_secret"

# App URL (for Stripe redirects - change to your production URL when deploying)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# WhatsApp Integration (for future implementation)
WHATSAPP_API_KEY="your_whatsapp_api_key"
WHATSAPP_PHONE_NUMBER_ID="your_whatsapp_phone_number_id"
WHATSAPP_ACCESS_TOKEN="your_whatsapp_access_token"

# Telegram Integration (for future implementation)
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"
